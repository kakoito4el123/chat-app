[gd_scene format=3 uid="uid://cp63dqyq0dvem"]

[sub_resource type="GDScript" id="GDScript_4xowi"]
script/source = "# main_menu.gd
extends CanvasLayer

var music_on := true
var music_player: AudioStreamPlayer
var music_btn: Button
var root: Control

func _ready() -> void:
	root = Control.new()
	root.set_anchors_preset(Control.PRESET_FULL_RECT)
	root.mouse_filter = Control.MOUSE_FILTER_IGNORE
	add_child(root)

	print(\"main_menu.gd loaded successfully\")

	_build_background()
	_build_music()
	_build_menu()

func _build_background() -> void:
	var bg := ColorRect.new()
	bg.set_anchors_preset(Control.PRESET_FULL_RECT)
	bg.color = Color(0.06, 0.05, 0.12)
	root.add_child(bg)

	# Мягкие плавающие фиолетово-синие пятна — \"живой\" фон, как в твоём лаунчере
	for i in range(4):
		var blob := ColorRect.new()
		blob.color = Color(randf_range(0.3, 0.6), randf_range(0.1, 0.3), randf_range(0.5, 0.95), 0.18)
		blob.size = Vector2(500, 500)
		blob.position = Vector2(randf_range(-150, 1100), randf_range(-150, 600))
		root.add_child(blob)

		var tw := create_tween().set_loops()
		var target := blob.position + Vector2(randf_range(-180, 180), randf_range(-140, 140))
		tw.tween_property(blob, \"position\", target, randf_range(7, 11)).set_trans(Tween.TRANS_SINE)
		tw.tween_property(blob, \"position\", blob.position, randf_range(7, 11)).set_trans(Tween.TRANS_SINE)

func _build_music() -> void:
	music_player = AudioStreamPlayer.new()
	add_child(music_player)
	music_player.volume_db = -8
	# Когда добавишь свой трек в проект (например res://audio/menu.ogg), раскомментируй:
	# music_player.stream = load(\"res://audio/menu.ogg\")
	# music_player.play()

func _build_menu() -> void:
	var center := CenterContainer.new()
	center.set_anchors_preset(Control.PRESET_FULL_RECT)
	root.add_child(center)

	var box := VBoxContainer.new()
	box.add_theme_constant_override(\"separation\", 16)
	center.add_child(box)

	var title := Label.new()
	title.text = \"IT-МАГНАТ\"
	title.add_theme_font_size_override(\"font_size\", 46)
	title.add_theme_color_override(\"font_color\", Color(0.85, 0.75, 1.0))
	title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	box.add_child(title)

	var subtitle := Label.new()
	subtitle.text = \"Симулятор Джуна\"
	subtitle.add_theme_font_size_override(\"font_size\", 16)
	subtitle.add_theme_color_override(\"font_color\", Color(0.6, 0.6, 0.72))
	subtitle.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	box.add_child(subtitle)

	var spacer := Control.new()
	spacer.custom_minimum_size = Vector2(0, 26)
	box.add_child(spacer)

	box.add_child(_make_button(\"▶  Играть\", _on_play_pressed))
	box.add_child(_make_button(\"⚙  Настройки\", _on_settings_pressed))
	music_btn = _make_button(\"🔊  Музыка: Вкл\", _on_music_pressed)
	box.add_child(music_btn)
	box.add_child(_make_button(\"✖  Выход\", _on_exit_pressed))

func _make_button(text: String, callback: Callable) -> Button:
	var btn := Button.new()
	btn.text = text
	btn.custom_minimum_size = Vector2(260, 52)
	btn.add_theme_font_size_override(\"font_size\", 17)
	btn.add_theme_color_override(\"font_color\", Color(0.92, 0.9, 1.0))

	var normal := StyleBoxFlat.new()
	normal.bg_color = Color(0.15, 0.12, 0.27)
	normal.set_corner_radius_all(14)
	normal.set_border_width_all(1)
	normal.border_color = Color(0.42, 0.32, 0.72)

	var hover := StyleBoxFlat.new()
	hover.bg_color = Color(0.3, 0.2, 0.55)
	hover.set_corner_radius_all(14)
	hover.set_border_width_all(1)
	hover.border_color = Color(0.6, 0.5, 0.95)

	var pressed := StyleBoxFlat.new()
	pressed.bg_color = Color(0.2, 0.15, 0.38)
	pressed.set_corner_radius_all(14)

	btn.add_theme_stylebox_override(\"normal\", normal)
	btn.add_theme_stylebox_override(\"hover\", hover)
	btn.add_theme_stylebox_override(\"pressed\", pressed)
	btn.pressed.connect(callback)
	return btn

func _on_play_pressed() -> void:
	print(\"[Меню] Играть — сюда позже подключим сцену геймплея кликера\")
	# get_tree().change_scene_to_file(\"res://gameplay.tscn\")

func _on_settings_pressed() -> void:
	print(\"[Меню] Настройки — заглушка, добавим панель громкости/качества позже\")

func _on_music_pressed() -> void:
	music_on = !music_on
	music_btn.text = \"🔊  Музыка: Вкл\" if music_on else \"🔇  Музыка: Выкл\"
	if music_player.stream:
		if music_on:
			music_player.play()
		else:
			music_player.stop()

func _on_exit_pressed() -> void:
	get_tree().quit()
"

